{
  "nodeModulesDir": "manual",
  "license": "MIT",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check && deno task oss:check",
    "test": "deno test -A",
    "i18n:check": "deno test i18n",
    "oss:check": "deno run --allow-read scripts/check-open-source.ts",
    "dev": "vite",
    "dev:local": "ATMOSPHERE_DB_BACKEND=turso TURSO_DATABASE_URL=file:./local.db deno task dev --host 127.0.0.1",
    "dev:seed": "deno run -A scripts/seed-local-dev.ts",
    "build": "deno install && deno run -A npm:vite@^7.1.3 build",
    "gen:images": "deno run -A --node-modules-dir=auto scripts/generate-static-images.ts",
    "gen:oauth-key": "deno run scripts/generate-oauth-key.ts",
    "extract:lottie-assets": "deno run -A scripts/extract-lottie-assets.ts",
    "db:migrate": "deno run -A scripts/migrate-db.ts",
    "db:migrate:neon": "deno run -A scripts/migrate-neon.ts",
    "db:migrate:postgres": "deno run -A scripts/migrate-postgres.ts",
    "db:backfill:neon": "deno run -A scripts/backfill-neon.ts",
    "db:copy:postgres": "deno run -A scripts/copy-postgres.ts",
    "db:diff:neon": "deno run -A scripts/diff-neon.ts",
    "db:smoke": "deno run -A scripts/smoke-db-runtime.ts",
    "smoke:production": "deno run --allow-env --allow-net scripts/smoke-production.ts",
    "smoke:public-shell": "deno run --allow-env --allow-net scripts/smoke-public-shell.ts",
    "smoke:picker-assets": "deno run --allow-env --allow-net scripts/smoke-picker-assets.ts",
    "e2e:login": "node scripts/e2e-login-flow.mjs",
    "release:stamp": "deno run --allow-env --allow-run=git,deno,railway scripts/stamp-release-vars.ts",
    "db:maintain": "deno run -A scripts/maintain-db.ts",
    "railway:seed-secrets": "deno run -A scripts/seed-railway-secrets.ts",
    "indexer": "deno run -A worker/indexer.ts",
    "pds:index": "deno run -A scripts/index-relay-pds-inventory.ts",
    "backfill:atstore": "deno run -A scripts/backfill-atstore.ts",
    "backfill:hosts": "deno run -A scripts/backfill-host-records.ts",
    "backfill:og-jpegs": "deno run -A scripts/backfill-og-jpegs.ts",
    "app-directory:run-jobs": "deno run -A scripts/run-app-directory-jobs.ts",
    "migrate:atstore": "deno run -A scripts/migrate-atmosphere-apps-to-atstore.ts",
    "rescore:app-trending": "deno run -A scripts/rescore-app-trending.ts",
    "publish:featured": "deno run -A scripts/publish-featured.ts",
    "host:dashboard:check": "deno run -A scripts/check-host-dashboard.ts",
    "host:conformance": "deno run -A scripts/check-host-conformance.ts",
    "host:conformance:smoke": "deno run -A scripts/smoke-host-conformance.ts",
    "host:mock": "deno run -A scripts/mock-pds-host.ts",
    "lex:lint": "goat lex lint lexicons/",
    "lex:check-dns": "goat lex check-dns --example-did did:plc:ab7uvkn4kyf7l7prl26pz4r2 lexicons/",
    "lex:status": "goat lex status lexicons/",
    "lex:publish": "goat lex publish lexicons/",
    "lex:publish:update": "goat lex publish --update lexicons/",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*",
    ".claude/worktrees/**"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "@libsql/client": "npm:@libsql/client@^0.15.0",
    "@neon/serverless": "jsr:@neon/serverless@^1.0.1",
    "pg": "npm:pg@^8.16.3",
    "@types/pg": "npm:@types/pg@^8.15.6",
    "sharp": "npm:sharp@0.34.5",
    "playwright": "npm:playwright@1.61.1"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "deploy": {
    "org": "atmospheremoney",
    "app": "atmosphere-account"
  }
}
