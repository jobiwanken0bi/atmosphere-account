{
  "lexicon": 1,
  "id": "com.atmosphereaccount.registry.profile",
  "defs": {
    "main": {
      "type": "record",
      "description": "A project's profile in the Atmosphere registry. Created by the project's own account on its PDS; one record per account.",
      "key": "literal:self",
      "record": {
        "type": "object",
        "required": ["name", "description", "categories", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 60,
            "maxGraphemes": 60,
            "description": "Display name for the project."
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "maxGraphemes": 500,
            "description": "Short description of the project."
          },
          "avatar": {
            "type": "blob",
            "accept": ["image/png", "image/jpeg", "image/webp"],
            "maxSize": 1000000,
            "description": "Project icon. Recommended 512x512 square."
          },
          "categories": {
            "type": "array",
            "minLength": 1,
            "maxLength": 4,
            "items": {
              "type": "string",
              "knownValues": [
                "app",
                "accountProvider",
                "moderator",
                "infrastructure"
              ]
            },
            "description": "All categories that apply to the project. A project can be both an app and an account provider, etc. The first item is treated as the primary category for sort/grouping."
          },
          "subcategories": {
            "type": "array",
            "maxLength": 10,
            "items": {
              "type": "string",
              "maxLength": 32
            },
            "description": "Open-ended subcategory tags. For apps: microblog, photo, video, blogging, music, events, clients, tools, social, reading, productivity."
          },
          "website": {
            "type": "string",
            "format": "uri",
            "maxLength": 256
          },
          "repoUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 256,
            "description": "Source repository URL. Tangled and GitHub URLs render with the matching icon on the public profile."
          },
          "openSource": {
            "type": "boolean",
            "description": "True if the project is open source. Adds an \"Open source\" badge on the public profile."
          },
          "bskyClient": {
            "type": "string",
            "knownValues": [
              "bluesky",
              "blacksky",
              "anisota",
              "deer",
              "witchsky"
            ],
            "description": "Preferred Bluesky-compatible client to open when visitors click the project's Bluesky link. Identity (handle) is the same across all clients."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
