# Copy to `.env` and fill in secrets. `.env` is gitignored.
#
# Turso/libSQL appview database (registry projection, app directory,
# OAuth state, app sessions, worker lease)
TURSO_DATABASE_URL=libsql://atmosphere-account-jobiwanken0bi.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=

# Neon/Postgres migration target.
# Use the pooled URL for web/app traffic and the direct URL for migrations,
# backfills, pg_dump/pg_restore, and other session-sensitive admin commands.
# Neon is not the active runtime DB until the Postgres adapter/cutover flags
# are added and validated; see docs/INFRASTRUCTURE.md.
# NEON_DATABASE_URL=postgresql://user:pass@ep-example-pooler.region.aws.neon.tech/db?sslmode=require
# NEON_DIRECT_DATABASE_URL=postgresql://user:pass@ep-example.region.aws.neon.tech/db?sslmode=require
# Runtime DB backend. Leave unset or set to `turso` in production until the
# Neon smoke suite and staged cutover are complete.
# ATMOSPHERE_DB_BACKEND=turso

# Site URL for OAuth redirects (production: https://atmosphereaccount.com).
# Local OAuth callbacks must use a loopback IP, not localhost. When this is a
# local loopback URL, the OAuth client automatically uses AT Protocol's special
# public dev client_id (`http://localhost?...`) instead of this local metadata
# URL, because auth servers cannot fetch 127.0.0.1 client metadata.
# FRESH_PUBLIC_SITE_URL=http://127.0.0.1:5174

# Curator DID for the featured directory record (indexer + publish:featured)
# ATMOSPHERE_DID=

# Comma-separated DIDs allowed to access /admin and /api/admin/* routes.
# Leave unset on forks — /admin will then be effectively unreachable.
# ADMIN_DIDS=

# Secret used to hash reporter IPs (24h dedup + soft rate-limit only).
# Falls back to SESSION_SECRET if unset; set a dedicated value in production
# so rotating one secret doesn't invalidate the other.
# REPORT_IP_SECRET=

# OAuth confidential client — run: deno task gen:oauth-key
#
# IMPORTANT: paste the values EXACTLY as printed by the script. The JWK
# values are JSON objects starting with `{` and ending with `}`. Do NOT
# wrap them in extra quotes. For Deno Deploy / hosted env UIs, paste the
# raw JSON object — leave the braces in place.
# OAUTH_PRIVATE_JWK={"kty":"EC",...,"kid":"..."}
# OAUTH_PUBLIC_JWK={"kty":"EC",...,"kid":"..."}
# OAUTH_KID=
# Required in production/hosted environments. Used to sign the app session cookie.
# SESSION_SECRET=

# Indexer worker (Railway); default is fine for the current production worker.
# JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
# Abort slow PDS/auth-server fetches so the worker queue cannot hang forever.
# ATPROTO_FETCH_TIMEOUT_MS=10000

# ATStore app-directory backfill.
# ATSTORE_REPO_DID=
# ATSTORE_SOCIAL_REPO_DIDS=

# Future community lexicon ingestion.
# COMMUNITY_APP_LEXICON_ENABLED=false
